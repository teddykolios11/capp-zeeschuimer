{

  "description": "Collect data while browsing social media platforms and upload it for analysis later",
  "manifest_version": 2,
  "name": "ClearFeed Capture",
  "version": "1.1.4",
  "homepage_url": "https://github.com/teddykolios11/capp-zeeschuimer",

  "browser_specific_settings": {
    "gecko": {
      "id": "zeeschuimer@clearfeed.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "images/clearfeed_capture.png",
    "96": "images/clearfeed_capture.png"
  },

  "browser_action": {
    "default_icon": "images/clearfeed_capture.png",
    "default_title": "ClearFeed Capture Status"
  },

  "permissions": [
    "webRequest", "webRequestBlocking", "webNavigation", "<all_urls>", "storage", "downloads", "activeTab", "tabs",
    "unlimitedStorage"
  ],

  "incognito": "spanning",

  "background": {
    "scripts": [
      "inc/dexie.js",
      "inc/he.js",
      "js/lib.js",
      "js/zs-background.js",
      "modules/twitter.js"
    ]
  }
}
